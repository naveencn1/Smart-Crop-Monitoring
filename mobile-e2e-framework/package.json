{
  "name": "mobile-e2e-appium-framework",
  "version": "1.0.0",
  "description": "Enterprise-ready Android Appium E2E automation framework using Node.js, Mocha, Chai, WebdriverIO, and ExcelJS.",
  "private": true,
  "scripts": {
    "test": "mocha --timeout 600000 ./tests/**/*.test.js --reporter mochawesome --reporter-options reportDir=reports/html,reportFilename=mochawesome,quiet=true,saveJson=true",
    "report": "node scripts/generate-xlsx.js",
    "ci": "npm test && npm run report",
    "appium": "npx appium --log-level info",
    "clean": "rimraf reports/* screenshots/* logs/* excel/*"
  },
  "dependencies": {
    "chai": "^4.3.8",
    "dotenv": "^16.3.1",
    "exceljs": "^4.3.0",
    "fs-extra": "^11.1.1",
    "moment": "^2.29.4",
    "winston": "^3.10.0",
    "webdriverio": "^8.20.0"
  },
  "devDependencies": {
    "appium": "^2.0.0",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-report-generator": "^6.2.0",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

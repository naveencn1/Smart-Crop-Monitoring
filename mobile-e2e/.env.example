# Appium Server Configuration
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
APPIUM_PATH=/

# Device Execution Configuration
# Set to 'emulator' for emulator execution or 'real' for real device execution
DEVICE_TYPE=emulator
DEVICE_NAME=emulator-5554
PLATFORM_VERSION=11.0
AUTOMATION_NAME=UiAutomator2

# Application Configuration (Use either APK_PATH or APP_PACKAGE + APP_ACTIVITY)
# Relative path to APK or absolute path
APK_PATH=./app/app-release.apk

# For pre-installed applications:
APP_PACKAGE=com.example.app
APP_ACTIVITY=com.example.app.MainActivity

# Test Execution settings
TEST_RETRY_COUNT=1
TEST_TIMEOUT=120000
ENVIRONMENT=staging

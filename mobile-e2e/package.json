{
  "name": "mobile-e2e-automation",
  "version": "1.0.0",
  "description": "Enterprise Appium E2E Mobile Automation Framework for Android",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "mocha tests/baseSetup.js tests/*.test.js --timeout 180000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=index,html=false,json=true",
    "report:html": "marge reports/index.json --reportDir=reports --reportFilename=html_report --charts=true",
    "test:run": "npm run test && npm run report:html",
    "lint": "eslint ."
  },
  "dependencies": {
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "mocha": "^10.4.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "webdriverio": "^8.39.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
